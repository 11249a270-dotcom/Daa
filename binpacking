#include <stdio.h>
void displayBins(int bin[], int count) {
int waste = 0;
printf("\nBin Status:\n");
for (int i = 0; i < count; i++) {
printf("Bin %d remaining: %d\n", i + 1, bin[i]);
waste += bin[i];
}
printf("Total unused space = %d\n", waste);
}
void firstfit(int itemsize[], int n, int capacity) {
int bin[n];
int bincount = 0;
for (int i = 0; i < n; i++) {
int placed = 0;
for (int j = 0; j < bincount; j++) {
if (bin[j] >= itemsize[i]) {
bin[j] -= itemsize[i];
printf("Item %d → Bin %d\n", itemsize[i], j + 1);
placed = 1;
break;
}
}
if (!placed) {
bin[bincount] = capacity - itemsize[i];
printf("Item %d → Bin %d\n", itemsize[i], bincount + 1);
bincount++;
}
}
printf("Total bins used = %d\n", bincount);
displayBins(bin, bincount);
}
void bestfit(int itemsize[], int n, int capacity) {
int bin[n];
int bincount = 0;
for (int i = 0; i < n; i++) {
int bestindex = -1;
int minspace = capacity + 1;
for (int j = 0; j < bincount; j++) {
if (bin[j] >= itemsize[i] &&
(bin[j] - itemsize[i]) < minspace) {
bestindex = j;
minspace = bin[j] - itemsize[i];
}
}
if (bestindex != -1) {
bin[bestindex] -= itemsize[i];
printf("Item %d → Bin %d\n", itemsize[i], bestindex + 1);
} else {
bin[bincount] = capacity - itemsize[i];
printf("Item %d → Bin %d\n", itemsize[i], bincount + 1);
bincount++;
}
}
printf("Total bins used = %d\n", bincount);
displayBins(bin, bincount);
}
int main() {
int n, capacity;
printf("Enter number of items: ");
scanf("%d", &n);
if (n <= 0) {
printf("Invalid number of items\n");
return 1;
}
printf("Enter bin capacity: ");
scanf("%d", &capacity);
if (capacity <= 0) {
printf("Invalid capacity\n");
return 1;
}
int itemsize[n];
for (int i = 0; i < n; i++) {
printf("Enter size of item %d: ", i + 1);
scanf("%d", &itemsize[i]);
if (itemsize[i] > capacity) {
printf("Item %d exceeds bin capacity!\n", itemsize[i]);
return 1;
}
}
printf("\n--- First Fit ---\n");
firstfit(itemsize, n, capacity);
printf("\n--- Best Fit ---\n");
bestfit(itemsize, n, capacity);
return 0;
}

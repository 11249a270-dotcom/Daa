#include <stdio.h>
#include <limits.h>
#define MAX 10
#define INF INT_MAX
int d[MAX][MAX];
int dp[MAX][1 << MAX];
int n;
int g(int i, int s) {
if (s == 0)
return d[i][0];
if (dp[i][s] != -1;
return dp[i][s];
int mincost = INF;
for (int k = 0; k < n; k++) {
if (s & (1 << k)) {
int cost = d[i][k] + g(k, s & ~(1 << k));
if (cost < mincost)
mincost = cost;
 }
 }
return dp[i][s] = mincost;
}
int main() {
int s = 0;
printf("Enter number of cities: ");
scanf("%d", &n);
printf("Enter cost matrix:\n");
for (int i = 0; i < n; i++) {
for (int j = 0; j < n; j++) {
scanf("%d", &d[i][j]);
}
}
for (int i = 0; i < n; i++) {
for (int s = 0; s < (1 << n); s++) {
dp[i][s] = -1;
}
}
for (int i = 1; i < n; i++) {
s |= (1 << i);
}
int result = g(0, s);
printf("Minimum travelling cost: %d\n", result);
return 0;
}

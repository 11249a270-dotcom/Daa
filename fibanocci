#include <stdio.h>
int fib(int n) {
    if (n == 0)
        return 0;
    if (n == 1)
        return 1;
    return fib(n - 1) + fib(n - 2);
}
int main() {
    int n;
    printf("Enter the number: ");
    scanf("%d", &n);
    if (n < 0) {
        printf("Invalid number\n");
    } else {
        printf("Fibonacci of %d is %d\n", n, fib(n));
    }
    return 0;
}
